<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PlanWise"
            android:textSize="28sp"
            android:textColor="@color/primary_blue"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Welcome Message -->
    <TextView
        android:id="@+id/welcome_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to PlanWise! 🎯\nPlan Smarter, Achieve More"
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="24dp" />

    <!-- Quick Actions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Actions"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Create Plan Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/create_plan_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/surface_white">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📝 Create New Plan"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➜"
                android:textSize="20sp"
                android:textColor="@color/primary_blue" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- View Plans Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/view_plans_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@color/surface_white">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋 My Plans"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➜"
                android:textSize="20sp"
                android:textColor="@color/primary_blue" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Recent Plans Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recent Plans"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Placeholder for recent plans -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No plans yet. Create your first plan! 🚀"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        android:padding="16dp"
        android:background="@drawable/result_background" />

</LinearLayout>